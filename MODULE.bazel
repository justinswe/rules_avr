    avr,
    "avr_cc_toolchains",
    "avr_gcc_darwin_arm64",
    "avr_gcc_linux_arm64",
    "avr_gcc_linux_x86",
    "avr_rust_analyzer_tools",
    "avr_rust_host_tools",
    "avr_rust_src",
    "avr_rust_toolchains",
)

register_toolchains(
    "@avr_cc_toolchains//:all",
    "@avr_rust_toolchains//:all",
    "//avrdude:all",
    dev_dependency = True,
)

foreign_tools = use_extension("@rules_foreign_cc//foreign_cc:extensions.bzl", "tools")
use_repo(
    foreign_tools,
    "cmake_3.31.8_toolchains",
    "ninja_1.13.0_toolchains",
    "rules_foreign_cc_framework_toolchains",
)

http_archive = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

http_archive(
    name = "avrdude_src",
    build_file = "//avrdude:avrdude.BUILD.bazel",
    patch_args = ["-p1"],
    patches = ["//avrdude:llvm_libtool.patch"],
    sha256 = "2d3016edd5281ea09627c20b865e605d4f5354fe98f269ce20522a5b910ab399",
    strip_prefix = "avrdude-8.1",
    urls = ["https://github.com/avrdudes/avrdude/archive/refs/tags/v8.1.tar.gz"],
)

gcc_source = use_repo_rule("//avr/private:gcc_source.bzl", "gcc_source")

gcc_source(
    name = "gcc_src",
    gcc_sha256 = "438fd996826b0c82485a29da03a72d71d6e3541a83ec702df4271f6fe025d24e",
    gcc_strip_prefix = "gcc-15.2.0",
    gcc_url = "https://ftpmirror.gnu.org/gnu/gcc/gcc-15.2.0/gcc-15.2.0.tar.xz",
    gmp_sha256 = "eae9326beb4158c386e39a356818031bd28f3124cf915f8c5b1dc4c7a36b4d7c",
