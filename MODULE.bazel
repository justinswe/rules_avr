    mpc_url = "https://gcc.gnu.org/pub/gcc/infrastructure/mpc-1.2.1.tar.gz",
    mpfr_sha256 = "feced2d430dd5a97805fa289fed3fc8ff2b094c02d05287fd6133e7f1f0ec926",
    mpfr_strip_prefix = "mpfr-4.1.0",
    mpfr_url = "https://gcc.gnu.org/pub/gcc/infrastructure/mpfr-4.1.0.tar.bz2",
)

http_archive(
    name = "binutils_src",
    build_file_content = """
filegroup(
    name = "all_srcs",
    srcs = glob(["**"]),
    visibility = ["//visibility:public"],
)
""",
    sha256 = "0f3152632a2a9ce066f20963e9bb40af7cf85b9b6c409ed892fd0676e84ecd12",
    strip_prefix = "binutils-2.46.0",
    urls = ["https://sourceware.org/pub/binutils/releases/binutils-2.46.0.tar.bz2"],
)

http_archive(
    name = "avr_libc_src",
    build_file_content = """
filegroup(
    name = "all_srcs",
    srcs = glob(["**"]),
    visibility = ["//visibility:public"],
)
""",
    sha256 = "2ec0827ec833ca6715a87221f31799d60da1c8638aa98eaafae42e0c2e302f5c",
    strip_prefix = "avr-libc-2.3.1",
