load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")

configure_make(
    name = "binutils",
    configure_options = [
        "--target=avr",
        "--disable-nls",
        "--disable-sim",
        "--disable-gdb",
        "--disable-werror",
        "--disable-shared",
        "--enable-static",
    ],
    env = {"AR": ""},
    lib_source = "@binutils_src//:all_srcs",
    out_bin_dir = "bin",
    out_binaries = [
        "avr-as",
        "avr-ld",
        "avr-objdump",
        "avr-size",
        "avr-nm",
        "avr-objcopy",
        "avr-strip",
        "avr-ar",
    ],
    tags = ["manual"],
    visibility = ["//visibility:public"],
)

configure_make(
    name = "gcc",
    build_data = [":binutils"],
    configure_options = [
        "--target=avr",
        "--enable-languages=c,c++",
        "--disable-nls",
        "--disable-libssp",
        "--disable-libcc1",
        "--with-gnu-as",
        "--with-gnu-ld",
        "--with-dwarf2",
        "--disable-shared",
        "--enable-static",
        "--with-system-zlib",
    ],
    env = {"AR": ""},
    lib_source = "@gcc_src//:all_srcs",
    out_bin_dir = "bin",
    out_binaries = [
        "avr-gcc",
        "avr-g++",
        "avr-cpp",
        "avr-gcov",
    ],
    out_data_dirs = [
        "avr",
        "libexec",
        "lib",
    ],
    tags = ["manual"],
    visibility = ["//visibility:public"],
)

configure_make(
    name = "libc",
    build_data = [
        ":binutils",
        ":gcc",
    ],
    configure_options = [
        "--host=avr",
    ],
    env = {"AR": ""},
    lib_source = "@avr_libc_src//:all_srcs",
    out_data_dirs = ["avr"],
    tags = ["manual"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "all_tools",
    srcs = [
        ":binutils",
        ":gcc",
        ":libc",
    ],
    tags = ["manual"],
    visibility = ["//visibility:public"],
)
